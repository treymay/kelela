<section id="tour" class="tour section section--cosmic">
  <div class="cosmic-grid" aria-hidden="true"></div>
  <div class="geo-accent geo-accent--2" aria-hidden="true"></div>

  <div class="container">
    <div class="tour__header" data-animate>
      <p class="section-label">{{ section.settings.eyebrow | default: 'On Tour' }}</p>
      <h2 class="section-title">{{ section.settings.title | default: 'Tour Dates' }}</h2>
      {%- if section.settings.description != blank -%}
        <p class="section-subtitle">{{ section.settings.description }}</p>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="tour__filters" data-animate>
        <button class="tour__filter is-active" data-filter="all">All Dates</button>
        {%- assign regions = '' -%}
        {%- for block in section.blocks -%}
          {%- if block.settings.region != blank -%}
            {%- unless regions contains block.settings.region -%}
              {%- assign regions = regions | append: block.settings.region | append: ',' -%}
            {%- endunless -%}
          {%- endif -%}
        {%- endfor -%}
        {%- assign region_list = regions | split: ',' -%}
        {%- for region in region_list -%}
          {%- if region != blank -%}
            <button class="tour__filter" data-filter="{{ region | handleize }}">{{ region }}</button>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <div class="tour__list" role="list">
        {%- for block in section.blocks -%}
          <article
            class="tour__item"
            role="listitem"
            data-region="{{ block.settings.region | handleize | default: 'all' }}"
            data-animate
            {{ block.shopify_attributes }}
          >
            <div class="tour__date">
              <time datetime="{{ block.settings.date | date: '%Y-%m-%d' }}">
                <span class="tour__date-month">{{ block.settings.date | date: '%b' }}</span>
                <span class="tour__date-day">{{ block.settings.date | date: '%d' }}</span>
              </time>
            </div>
            <div class="tour__details">
              <h3 class="tour__city">{{ block.settings.city }}</h3>
              <p class="tour__venue">{{ block.settings.venue }}</p>
              {%- if block.settings.region != blank -%}
                <span class="tour__region">{{ block.settings.region }}</span>
              {%- endif -%}
            </div>
            <div class="tour__action">
              {%- if block.settings.ticket_url != blank -%}
                <a href="{{ block.settings.ticket_url }}" class="btn btn--primary btn--inline-mobile" target="_blank" rel="noopener">
                  {{ block.settings.ticket_text | default: 'Tickets' }}
                  {% render 'icon', icon: 'external' %}
                </a>
              {%- elsif block.settings.sold_out -%}
                <span class="tour__sold-out">Sold Out</span>
              {%- else -%}
                <span class="tour__tba">TBA</span>
              {%- endif -%}
            </div>
          </article>
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="tour__empty" data-animate>
        <p>Add tour dates in the theme editor to populate this section.</p>
      </div>
    {%- endif -%}

    {%- if section.settings.view_all_url != blank -%}
      <div class="tour__footer" data-animate>
        <a href="{{ section.settings.view_all_url }}" class="btn btn--secondary">
          View Full Tour Schedule
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const filters = document.querySelectorAll('.tour__filter');
    const items = document.querySelectorAll('.tour__item');
    if (!filters.length) return;

    filters.forEach(btn => {
      btn.addEventListener('click', () => {
        filters.forEach(f => f.classList.remove('is-active'));
        btn.classList.add('is-active');
        const region = btn.dataset.filter;
        items.forEach(item => {
          const show = region === 'all' || item.dataset.region === region;
          item.style.display = show ? '' : 'none';
        });
      });
    });
  });
</script>

{% schema %}
{
  "name": "Tour Dates",
  "tag": "section",
  "class": "section-tour",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "On Tour"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Tour Dates"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Catch Kelela live on the New Avatar world tour."
    },
    {
      "type": "url",
      "id": "view_all_url",
      "label": "Full tour page link"
    }
  ],
  "blocks": [
    {
      "type": "date",
      "name": "Tour date",
      "settings": [
        {
          "type": "text",
          "id": "date",
          "label": "Date",
          "info": "Format: YYYY-MM-DD",
          "default": "2026-09-15"
        },
        {
          "type": "text",
          "id": "city",
          "label": "City",
          "default": "Los Angeles"
        },
        {
          "type": "text",
          "id": "venue",
          "label": "Venue",
          "default": "The Wiltern"
        },
        {
          "type": "text",
          "id": "region",
          "label": "Region",
          "default": "North America",
          "info": "Used for filtering (e.g. North America, Europe, UK)"
        },
        {
          "type": "url",
          "id": "ticket_url",
          "label": "Ticket URL"
        },
        {
          "type": "text",
          "id": "ticket_text",
          "label": "Ticket button text",
          "default": "Tickets"
        },
        {
          "type": "checkbox",
          "id": "sold_out",
          "label": "Sold out",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Tour Dates",
      "blocks": [
        {
          "type": "date",
          "settings": {
            "date": "2026-09-15",
            "city": "Los Angeles",
            "venue": "The Wiltern",
            "region": "North America"
          }
        },
        {
          "type": "date",
          "settings": {
            "date": "2026-09-18",
            "city": "Brooklyn",
            "venue": "Brooklyn Steel",
            "region": "North America"
          }
        },
        {
          "type": "date",
          "settings": {
            "date": "2026-10-05",
            "city": "London",
            "venue": "O2 Academy Brixton",
            "region": "Europe"
          }
        },
        {
          "type": "date",
          "settings": {
            "date": "2026-10-12",
            "city": "Berlin",
            "venue": "Huxley's Neue Welt",
            "region": "Europe"
          }
        }
      ]
    }
  ]
}
{% endschema %}

<style>
  .tour__header {
    text-align: center;
    margin-bottom: 3rem;
  }
  .tour__header .section-subtitle {
    margin-inline: auto;
  }
  .tour__filters {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 2.5rem;
  }
  .tour__filter {
    padding: 0.5rem 1.25rem;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: var(--radius-sm);
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .tour__filter:hover,
  .tour__filter.is-active {
    border-color: var(--color-primary);
    color: var(--color-primary);
    background: rgba(0, 229, 192, 0.08);
  }
  .tour__list {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: rgba(255, 255, 255, 0.06);
    border-radius: var(--radius-md);
    overflow: hidden;
  }
  .tour__item {
    display: grid;
    grid-template-columns: 100px 1fr auto;
    gap: 1.5rem;
    align-items: center;
    padding: 1.5rem 2rem;
    background: var(--color-surface);
    transition: background 0.2s ease;
  }
  .tour__item:hover {
    background: rgba(0, 229, 192, 0.04);
  }
  .tour__date time {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .tour__date-month {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-primary);
  }
  .tour__date-day {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 700;
    line-height: 1;
  }
  .tour__city {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 0.25rem;
  }
  .tour__venue {
    color: var(--color-text-muted);
    font-size: 0.9375rem;
  }
  .tour__region {
    display: inline-block;
    margin-top: 0.5rem;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-secondary);
  }
  .tour__sold-out,
  .tour__tba {
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }
  .tour__sold-out {
    color: #ff6b6b;
  }
  .tour__empty {
    text-align: center;
    padding: 4rem 2rem;
    color: var(--color-text-muted);
    border: 1px dashed rgba(0, 229, 192, 0.3);
    border-radius: var(--radius-md);
  }
  .tour__footer {
    text-align: center;
    margin-top: 2.5rem;
  }
  @media (max-width: 768px) {
    .tour__item {
      grid-template-columns: 70px 1fr;
      grid-template-rows: auto auto;
      padding: 1.25rem;
      gap: 1rem;
    }
    .tour__action {
      grid-column: 1 / -1;
    }
    .tour__action .btn {
      width: 100%;
    }
  }
</style>
