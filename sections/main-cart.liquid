<section class="cart-page section">
  <div class="container">
    <h1 class="section-title">Cart</h1>

    {%- if cart.item_count > 0 -%}
      <form action="{{ routes.cart_url }}" method="post" class="cart-page__form">
        <div class="cart-page__items">
          {%- for item in cart.items -%}
            <article class="cart-page__item">
              <div class="cart-page__item-image">
                {%- if item.image -%}
                  {{ item.image | image_url: width: 200 | image_tag: loading: 'lazy', alt: item.title }}
                {%- endif -%}
              </div>
              <div class="cart-page__item-details">
                <h2 class="cart-page__item-title">{{ item.product.title }}</h2>
                {%- unless item.product.has_only_default_variant -%}
                  <p class="cart-page__item-variant">{{ item.variant.title }}</p>
                {%- endunless -%}
                <p class="cart-page__item-price">{{ item.final_line_price | money }}</p>
              </div>
              <div class="cart-page__item-qty">
                <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" class="input-field cart-page__qty" aria-label="Quantity for {{ item.title }}">
              </div>
            </article>
          {%- endfor -%}
        </div>

        <div class="cart-page__footer">
          <p class="cart-page__total">
            <span>Subtotal</span>
            <strong>{{ cart.total_price | money }}</strong>
          </p>
          <div class="cart-page__actions">
            <button type="submit" name="update" class="btn btn--ghost">Update Cart</button>
            <button type="submit" name="checkout" class="btn btn--primary btn--large">Checkout</button>
          </div>
          {%- if settings.trust_badge != blank -%}
            <span class="trust-badge">
              {% render 'icon', icon: 'check' %}
              {{ settings.trust_badge }}
            </span>
          {%- endif -%}
        </div>
      </form>
    {%- else -%}
      <div class="cart-page__empty">
        <p>Your cart is empty.</p>
        <a href="#merch" class="btn btn--primary">Shop Merch</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Cart",
  "settings": []
}
{% endschema %}

<style>
  .cart-page {
    padding-top: calc(var(--header-height) + 2rem);
    min-height: 60vh;
  }
  .cart-page__items {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: rgba(255,255,255,0.06);
    border-radius: var(--radius-md);
    overflow: hidden;
    margin-bottom: 2rem;
  }
  .cart-page__item {
    display: grid;
    grid-template-columns: 100px 1fr auto;
    gap: 1.5rem;
    align-items: center;
    padding: 1.5rem;
    background: var(--color-surface);
  }
  .cart-page__item-image img {
    width: 100px;
    height: 100px;
    object-fit: cover;
    border-radius: var(--radius-sm);
  }
  .cart-page__item-title {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    margin-bottom: 0.25rem;
  }
  .cart-page__item-variant {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }
  .cart-page__item-price {
    font-weight: 700;
    color: var(--color-primary);
    margin-top: 0.5rem;
  }
  .cart-page__qty {
    width: 80px;
    text-align: center;
  }
  .cart-page__footer {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 1rem;
  }
  .cart-page__total {
    font-size: 1.25rem;
    display: flex;
    gap: 2rem;
  }
  .cart-page__actions {
    display: flex;
    gap: 1rem;
  }
  .cart-page__empty {
    text-align: center;
    padding: 4rem 2rem;
  }
  .cart-page__empty p {
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }
  @media (max-width: 768px) {
    .cart-page__item {
      grid-template-columns: 80px 1fr;
    }
    .cart-page__item-qty {
      grid-column: 1 / -1;
    }
    .cart-page__actions {
      flex-direction: column;
      width: 100%;
    }
    .cart-page__actions .btn {
      width: 100%;
    }
  }
</style>
