<section id="pre-order" class="hero section" data-animate>
  <div class="hero__bg">
    {%- if section.settings.background_image != blank -%}
      {{ section.settings.background_image | image_url: width: 1920 | image_tag:
        loading: 'eager',
        class: 'hero__bg-image',
        alt: section.settings.album_title
      }}
    {%- endif -%}
    <div class="hero__overlay"></div>
    <div class="hero__particles" aria-hidden="true"></div>
  </div>

  <div class="hero__content container">
    <div class="hero__text">
      {%- if section.settings.eyebrow != blank -%}
        <p class="section-label hero__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      <h1 class="hero__title">
        {%- if section.settings.album_title != blank -%}
          {{ section.settings.album_title }}
        {%- else -%}
          NEW<br><span class="hero__title-accent">AVATAR</span>
        {%- endif -%}
      </h1>

      {%- if section.settings.release_date != blank -%}
        <p class="hero__date">{{ section.settings.release_date }}</p>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <p class="hero__description">{{ section.settings.description }}</p>
      {%- endif -%}

      <div class="hero__actions">
        {%- if section.settings.preorder_product != blank -%}
          <a href="{{ section.settings.preorder_product.url }}" class="btn btn--primary btn--large">
            {{ section.settings.cta_text | default: 'Pre-Order Album' }}
          </a>
        {%- elsif section.settings.cta_url != blank -%}
          <a href="{{ section.settings.cta_url }}" class="btn btn--primary btn--large">
            {{ section.settings.cta_text | default: 'Pre-Order Album' }}
          </a>
        {%- else -%}
          <a href="#merch" class="btn btn--primary btn--large">
            {{ section.settings.cta_text | default: 'Pre-Order Album' }}
          </a>
        {%- endif -%}

        {%- if section.settings.ships_text != blank -%}
          <span class="trust-badge">
            {% render 'icon', icon: 'check' %}
            {{ section.settings.ships_text }}
          </span>
        {%- endif -%}
      </div>
    </div>

    <div class="hero__artwork">
      {%- if section.settings.album_art != blank -%}
        <div class="hero__artwork-frame">
          {{ section.settings.album_art | image_url: width: 800 | image_tag:
            loading: 'eager',
            class: 'hero__artwork-image',
            alt: section.settings.album_title
          }}
          <div class="hero__artwork-glow" aria-hidden="true"></div>
        </div>
      {%- else -%}
        <div class="hero__artwork-placeholder">
          <div class="hero__artwork-inner">
            <span class="hero__artwork-text">NEW<br>AVATAR</span>
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>

  <div class="hero__scroll-indicator" aria-hidden="true">
    <span>Scroll</span>
    <div class="hero__scroll-line"></div>
  </div>
</section>

{% schema %}
{
  "name": "Hero — Pre-Order",
  "tag": "section",
  "class": "section-hero-preorder",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "The new album"
    },
    {
      "type": "text",
      "id": "album_title",
      "label": "Album title",
      "default": "NEW AVATAR"
    },
    {
      "type": "text",
      "id": "release_date",
      "label": "Release date",
      "default": "Out July 10, 2026"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "A new sonic dimension. Pre-order the album on vinyl, CD, and digital — exclusive variants available for a limited time."
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "image_picker",
      "id": "album_art",
      "label": "Album artwork"
    },
    {
      "type": "product",
      "id": "preorder_product",
      "label": "Pre-order product"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA link (if no product selected)"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA button text",
      "default": "Pre-Order Album"
    },
    {
      "type": "text",
      "id": "ships_text",
      "label": "Trust badge text",
      "default": "Ships July 10"
    }
  ],
  "presets": [
    {
      "name": "Hero — Pre-Order"
    }
  ]
}
{% endschema %}

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    padding-top: var(--header-height);
    overflow: hidden;
  }
  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero__bg-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero__overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(135deg, rgba(10, 14, 20, 0.95) 0%, rgba(10, 14, 20, 0.7) 50%, rgba(10, 14, 20, 0.85) 100%),
      radial-gradient(ellipse at 70% 50%, rgba(0, 180, 255, 0.15) 0%, transparent 60%);
  }
  .hero__particles {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(2px 2px at 20% 30%, rgba(0, 229, 192, 0.4), transparent),
      radial-gradient(2px 2px at 60% 70%, rgba(0, 180, 255, 0.3), transparent),
      radial-gradient(1px 1px at 80% 20%, rgba(212, 175, 55, 0.3), transparent),
      radial-gradient(1px 1px at 40% 80%, rgba(0, 229, 192, 0.2), transparent);
    background-size: 100% 100%;
    animation: float 20s ease-in-out infinite;
  }
  .hero__content {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    padding-block: 4rem;
  }
  .hero__title {
    font-size: clamp(3.5rem, 10vw, 7rem);
    line-height: 0.95;
    margin-bottom: 1rem;
  }
  .hero__title-accent {
    background: var(--gradient-cosmic);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero__date {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-gold);
    letter-spacing: 0.05em;
    margin-bottom: 1.5rem;
  }
  .hero__description {
    font-size: 1.0625rem;
    color: var(--color-text-muted);
    max-width: 480px;
    margin-bottom: 2rem;
    line-height: 1.7;
  }
  .hero__actions {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
  }
  .hero__artwork-frame {
    position: relative;
    aspect-ratio: 1;
    max-width: 480px;
    margin-inline: auto;
  }
  .hero__artwork-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--radius-md);
    position: relative;
    z-index: 1;
  }
  .hero__artwork-glow {
    position: absolute;
    inset: -20%;
    background: radial-gradient(circle, rgba(0, 229, 192, 0.3) 0%, transparent 70%);
    z-index: 0;
    animation: pulse-ring 4s ease-in-out infinite;
  }
  .hero__artwork-placeholder {
    aspect-ratio: 1;
    max-width: 480px;
    margin-inline: auto;
    background: linear-gradient(135deg, rgba(0, 180, 255, 0.2), rgba(0, 229, 192, 0.2));
    border: 1px solid rgba(0, 229, 192, 0.3);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    animation: float 6s ease-in-out infinite;
  }
  .hero__artwork-inner {
    text-align: center;
  }
  .hero__artwork-text {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    line-height: 1.2;
    background: var(--gradient-cosmic);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero__scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.6875rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    z-index: 1;
  }
  .hero__scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, var(--color-primary), transparent);
    animation: float 2s ease-in-out infinite;
  }
  @media (max-width: 900px) {
    .hero__content {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 2rem;
    }
    .hero__actions {
      align-items: center;
    }
    .hero__description {
      margin-inline: auto;
    }
    .hero__artwork-frame,
    .hero__artwork-placeholder {
      max-width: 320px;
    }
  }
</style>
