<article class="product-card" data-animate>
  <a href="{{ product.url }}" class="product-card__link">
    <div class="product-card__image">
      {%- if product.featured_image -%}
        {{ product.featured_image | image_url: width: 600 | image_tag:
          loading: 'lazy',
          widths: '300, 400, 600',
          sizes: '(max-width: 768px) 50vw, 25vw',
          alt: product.featured_image.alt | default: product.title
        }}
      {%- else -%}
        <div class="product-card__placeholder">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
            <rect x="3" y="3" width="18" height="18" rx="2"/>
            <circle cx="8.5" cy="8.5" r="1.5"/>
            <path d="M21 15l-5-5L5 21"/>
          </svg>
        </div>
      {%- endif -%}
    </div>

    {%- if product.tags contains 'limited' or product.tags contains 'exclusive' -%}
      <span class="product-card__badge">Limited</span>
    {%- elsif product.tags contains 'pre-order' -%}
      <span class="product-card__badge">Pre-Order</span>
    {%- endif -%}

    <div class="product-card__info">
      <h3 class="product-card__title">{{ product.title }}</h3>
      <p class="product-card__price">
        {%- if product.price_varies -%}
          From {{ product.price_min | money }}
        {%- else -%}
          {{ product.price | money }}
        {%- endif -%}
      </p>
    </div>
  </a>

  <div class="product-card__buy">
    {%- if product.available == false -%}
      <span class="btn btn--ghost product-card__btn" aria-disabled="true">Sold Out</span>
    {%- elsif product.has_only_default_variant -%}
      {%- form 'product', product, class: 'product-card__form' -%}
        <input type="hidden" name="id" value="{{ product.first_available_variant.id }}">
        <button type="submit" name="add" class="btn btn--secondary product-card__btn">
          {%- if product.tags contains 'pre-order' -%}Pre-Order{%- else -%}Add to Cart{%- endif -%}
        </button>
      {%- endform -%}
    {%- else -%}
      <a href="{{ product.url }}" class="btn btn--secondary product-card__btn">Choose Options</a>
    {%- endif -%}
  </div>
</article>

<style>
  .product-card__link {
    display: block;
    color: inherit;
  }
  .product-card__placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    color: rgba(124, 232, 213, 0.3);
  }
  .product-card__buy {
    padding: 0 1.25rem 1.25rem;
  }
  .product-card__form {
    margin: 0;
  }
  .product-card__btn {
    width: 100%;
    padding-block: 0.8rem;
  }
  [data-animate] {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  [data-animate].is-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>
