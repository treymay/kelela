{%- liquid
  assign font_heading = settings.font_heading
  assign font_body = settings.font_body
  assign font_heading_bold = font_heading | font_modify: 'weight', 'bolder'
  assign font_body_bold = font_body | font_modify: 'weight', 'bolder'
-%}

<style>
  {{ font_heading | font_face: font_display: 'swap' }}
  {{ font_body | font_face: font_display: 'swap' }}
  {%- if font_heading_bold -%}
    {{ font_heading_bold | font_face: font_display: 'swap' }}
  {%- endif -%}
  {%- if font_body_bold -%}
    {{ font_body_bold | font_face: font_display: 'swap' }}
  {%- endif -%}

  :root {
    --color-primary: {{ settings.color_primary }};
    --color-secondary: {{ settings.color_secondary }};
    --color-gold: {{ settings.color_gold }};
    --color-bg: {{ settings.color_background }};
    --color-surface: {{ settings.color_surface }};
    --color-text: {{ settings.color_text }};
    --color-text-muted: rgba(240, 244, 248, 0.65);
    --font-heading: {{ font_heading.family }}, {{ font_heading.fallback_families }};
    --font-body: {{ font_body.family }}, {{ font_body.fallback_families }};
    --font-heading-weight: {{ font_heading.weight }};
    --font-body-weight: {{ font_body.weight }};
    --font-heading-style: {{ font_heading.style }};
    --font-body-style: {{ font_body.style }};
    --gradient-cosmic: linear-gradient(135deg, var(--color-secondary) 0%, var(--color-primary) 55%, #3A9B87 100%);
    --gradient-glow: radial-gradient(ellipse at 50% 0%, rgba(143, 191, 255, 0.16) 0%, transparent 60%);
    --shadow-glow: 0 0 50px rgba(124, 232, 213, 0.22);
    --shadow-glow-blue: 0 0 50px rgba(143, 191, 255, 0.18);
    --radius-sm: 10px;
    --radius-md: 16px;
    --radius-lg: 28px;
    --section-padding: clamp(4rem, 10vw, 8rem);
    --container-max: 1280px;
    --header-height: 72px;
  }
</style>
