{%- liquid
  assign font_heading = settings.font_heading
  assign font_body = settings.font_body
-%}

:root {
  --color-primary: {{ settings.color_primary }};
  --color-secondary: {{ settings.color_secondary }};
  --color-gold: {{ settings.color_gold }};
  --color-bg: {{ settings.color_background }};
  --color-surface: {{ settings.color_surface }};
  --color-text: {{ settings.color_text }};
  --color-text-muted: rgba(240, 244, 248, 0.65);
  --font-heading: {{ font_heading.family }}, {{ font_heading.fallback_families }};
  --font-body: {{ font_body.family }}, {{ font_body.fallback_families }};
  --font-heading-weight: {{ font_heading.weight }};
  --font-body-weight: {{ font_body.weight }};
  --font-heading-style: {{ font_heading.style }};
  --font-body-style: {{ font_body.style }};
  --gradient-cosmic: linear-gradient(135deg, var(--color-secondary) 0%, var(--color-primary) 50%, #006B5A 100%);
  --gradient-glow: radial-gradient(ellipse at 50% 0%, rgba(0, 180, 255, 0.25) 0%, transparent 60%);
  --shadow-glow: 0 0 40px rgba(0, 229, 192, 0.3);
  --shadow-glow-blue: 0 0 40px rgba(0, 180, 255, 0.25);
  --radius-sm: 4px;
  --radius-md: 8px;
  --radius-lg: 16px;
  --section-padding: clamp(4rem, 10vw, 8rem);
  --container-max: 1280px;
  --header-height: 72px;
}

@font-face {
  font-display: swap;
}
