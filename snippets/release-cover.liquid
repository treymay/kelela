{%- comment -%}
  Renders an album cover for the Releases page.
  Accepts: image (image_picker value), title (string for alt text / placeholder)
{%- endcomment -%}
<div class="release__cover">
  {%- if image != blank -%}
    {{ image | image_url: width: 800 | image_tag:
      loading: 'lazy',
      widths: '400, 600, 800',
      sizes: '(max-width: 900px) 100vw, 300px',
      alt: title | append: ' — album artwork'
    }}
  {%- else -%}
    <div class="release__cover-placeholder" aria-hidden="true">
      <span>{{ title | slice: 0, 1 | upcase }}</span>
    </div>
  {%- endif -%}
</div>
